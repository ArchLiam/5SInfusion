<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Days__c</fullName>
    <label>Days</label>
    <type>Number</type>
    <formula>Service_End_Date__c - Service_Start_Date__c + 1</formula>
    <formulaTreatBlanksAs>BlankAsBlank</formulaTreatBlanksAs>
    <precision>4</precision>
    <scale>0</scale>
    <description>Number of calendar days in the service period (inclusive of start and end).</description>
</CustomField>
